# HyperDex .env template — copier vers backend/.env et remplir
# JAMAIS commiter .env

# Hyperliquid — wallet API (séparé du wallet de fonds, autorisé sur app.hyperliquid.xyz/API)
HL_ACCOUNT_ADDRESS=0x...
HL_API_PRIVATE_KEY=
HL_NETWORK=mainnet
# (testnet pour le dev initial : HL_NETWORK=testnet, base url change automatiquement via le SDK)

# DB
DATABASE_URL=sqlite:///./data/hyperdex.db

# Flags
PAPER_ONLY=true
LIVE_ENABLED=false
